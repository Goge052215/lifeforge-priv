{
  "functions": {
    "api/handler.js": {
      "runtime": "@vercel/node@5.3.24",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": "{../locales/**/*,src/core/bin/**/*,src/core/models/**/*}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/handler"
    }
  ]
}
